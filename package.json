{
  "name": "accessible-astro-starter",
  "description": "An Accessible Starter Theme for Astro including several accessibility features and tools to help you build faster.",
  "version": "5.0.1",
  "author": "Incluud",
  "license": "MIT",
  "type": "module",
  "homepage": "https://accessible-astro-starter.incluud.dev/",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "start:prod": "node ./dist/server/entry.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "typecheck": "astro check",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test": "npm run test:unit && npm run test:e2e",
    "check": "npm run lint && npm run typecheck && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "astro",
    "astro-component",
    "astro-components",
    "accessible",
    "accessibility",
    "a11y",
    "wcag",
    "responsive",
    "ui-library",
    "ui-components",
    "blog",
    "portfolio"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/incluud/accessible-astro-starter.git"
  },
  "bugs": {
    "url": "https://github.com/incluud/accessible-astro-starter/issues"
  },
  "devDependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/node": "^9.5.0",
    "@astrojs/partytown": "^2.1.4",
