---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Badge, Heading, Link, Pagination } from 'accessible-astro-components'
import PublicContentCard from '@components/PublicContentCard.astro'
import { slugify } from '@utils/slugify'
import { getPaginatedProjects, getProjectTags } from '@server/content/projects'

const PAGE_SIZE = 6
const PUBLIC_CONTENT_CACHE_TTL_MS = 30000
const fallbackProjectImages = [
  '/projects/project-image-1.png',
  '/projects/project-image-2.png',
  '/projects/project-image-3.png',
  '/projects/project-image-4.png',
  '/projects/project-image-5.png',
  '/projects/project-image-6.png',
]

const uniqueTagLabels = await getProjectTags({ cacheTtlMs: PUBLIC_CONTENT_CACHE_TTL_MS })
const uniqueTags = uniqueTagLabels.map((label) => ({
  label,
  slug: slugify(label),
}))

const currentTagSlug = slugify((Astro.params.tag || '').trim())
const currentTag =
  uniqueTags.find((tag) => tag.slug === currentTagSlug) ||
  ({ label: Astro.params.tag || 'tag', slug: currentTagSlug || 'tag' } as { label: string; slug: string })

const rawPageParam = (Astro.params.page || '').split('/').filter(Boolean)[0] || '1'
const parsedPage = Number.parseInt(rawPageParam, 10)
const currentPage = Number.isInteger(parsedPage) && parsedPage > 0 ? parsedPage : 1

let paginatedProjects = await getPaginatedProjects({
  page: currentPage,
  pageSize: PAGE_SIZE,
  cacheTtlMs: PUBLIC_CONTENT_CACHE_TTL_MS,
  tag: currentTag.label,
})

const initialLastPage = Math.max(1, Math.ceil(paginatedProjects.totalItems / PAGE_SIZE))
const safePage = Math.min(currentPage, initialLastPage)

if (safePage !== currentPage) {
  paginatedProjects = await getPaginatedProjects({
    page: safePage,
    pageSize: PAGE_SIZE,
    cacheTtlMs: PUBLIC_CONTENT_CACHE_TTL_MS,
    tag: currentTag.label,
  })
}

const pageProjects = paginatedProjects.items.map((project, index) => ({
  ...project,
  featuredImage: project.coverImageUrl || fallbackProjectImages[index % fallbackProjectImages.length],
}))
const totalProjects = paginatedProjects.totalItems
const lastPage = Math.max(1, Math.ceil(totalProjects / PAGE_SIZE))
const startIndex = (safePage - 1) * PAGE_SIZE
const endIndex = startIndex + PAGE_SIZE
const viewStart = totalProjects === 0 ? 0 : startIndex + 1
const viewEnd = totalProjects === 0 ? 0 : Math.min(endIndex, totalProjects)
const previousPageHref =
  safePage > 1
    ? safePage === 2
      ? `/portfolio/tag/${currentTag.slug}`
      : `/portfolio/tag/${currentTag.slug}/${safePage - 1}`
    : null
const nextPageHref = safePage < lastPage ? `/portfolio/tag/${currentTag.slug}/${safePage + 1}` : null
const firstPageHref = safePage > 1 ? `/portfolio/tag/${currentTag.slug}` : null
const lastPageHref = safePage < lastPage ? `/portfolio/tag/${currentTag.slug}/${lastPage}` : null
---

<DefaultLayout
  title={`${currentTag.label} Projects | Ibnu Rizal Mutaqim`}
  description={`Portfolio projects by Ibnu Rizal Mutaqim tagged with ${currentTag.label}.`}
>
  <PageHeader
    title={`Portofolio: ${currentTag.label}`}
    subtitle={`Menampilkan ${totalProjects} proyek dengan tag "${currentTag.label}". <a href="/portfolio">View all projects</a>.`}
    bgType="gradient"
    customBreadcrumbLabels={{
      [currentTag.slug]: currentTag.label,
    }}
    joinLastBreadcrumb={true}
  />

  <section class="portfolio-tag-list my-10 md:my-12">
    <div class="container">
      <Heading level="h2" size="h5" class="mb-2">Tag</Heading>
      <div class="tag-cloud flex flex-wrap gap-3 md:gap-4">
        <Link href="/portfolio">Semua proyek</Link>
        {
          uniqueTags.map((tag: { label: string; slug: string }) => {
            const isCurrentTag = tag.slug === currentTag.slug
            return isCurrentTag ? (
              <Link href={'/portfolio/tag/' + tag.slug} disabled class="disabled">
                {tag.label}
              </Link>
            ) : (
              <Link href={'/portfolio/tag/' + tag.slug}>{tag.label}</Link>
            )
          })
        }
      </div>
      <p class="mt-6 text-sm md:mt-8">
        <em
          >Menampilkan proyek {viewStart} sampai {viewEnd} dari total {totalProjects} proyek dengan tag "{
            currentTag.label
          }"</em
        >
      </p>
      <ul class="portfolio-grid mt-3">
        {
          pageProjects.map((project) => (
            <li>
              <PublicContentCard
                imageLoading="lazy"
                fetchpriority="low"
                img={project.featuredImage}
                url={'/portfolio/' + project.slug}
                title={project.title}
                headingLevel="h2"
                footer={'Peran: ' + project.author}
                fullHeight={true}
              >
                <span slot="meta">
                  {project.tags.map((tag) => {
                    const isCurrentTag = slugify(tag) === currentTag.slug
                    return isCurrentTag ? <Badge class="bg-blue-600 text-white">{tag}</Badge> : <Badge>{tag}</Badge>
                  })}
                </span>
                {project.description}
              </PublicContentCard>
            </li>
          ))
        }
      </ul>

      {
        lastPage > 1 && (
          <div class="mt-10 grid place-content-center md:mt-12">
            <Pagination
              firstPage={firstPageHref}
              previousPage={previousPageHref}
              nextPage={nextPageHref}
              lastPage={lastPageHref}
              currentPage={`${safePage}`}
              totalPages={`${lastPage}`}
              ariaLabel={`Pagination portofolio tag ${currentTag.label}`}
            />
          </div>
        )
      }
    </div>
  </section>
</DefaultLayout>

<style lang="scss" is:global>
  .portfolio-tag-list .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(250px, 100%), 1fr));
    gap: clamp(1rem, 2.2vw, 1.45rem);
  }

  .portfolio-tag-list .portfolio-grid > li {
    min-inline-size: 0;
  }

  .portfolio-tag-list .portfolio-grid :is(h2, h3, h4, p, a, span) {
    overflow-wrap: anywhere;
  }

  .portfolio-tag-list .tag-cloud a {
    white-space: normal;
    overflow-wrap: anywhere;
  }
</style>
