---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Badge, Heading, Link, Pagination } from 'accessible-astro-components'
import PublicContentCard from '@components/PublicContentCard.astro'
import { slugify } from '@utils/slugify'
import { getPaginatedProjects, getProjectTags } from '@server/content/projects'

const PAGE_SIZE = 6
const PUBLIC_CONTENT_CACHE_TTL_MS = 30000
const fallbackProjectImages = [
  '/projects/project-image-1.png',
  '/projects/project-image-2.png',
  '/projects/project-image-3.png',
  '/projects/project-image-4.png',
  '/projects/project-image-5.png',
  '/projects/project-image-6.png',
]

const rawPageParam = (Astro.params.page || '').split('/').filter(Boolean)[0] || '1'
const parsedPage = Number.parseInt(rawPageParam, 10)
const currentPage = Number.isInteger(parsedPage) && parsedPage > 0 ? parsedPage : 1

const uniqueTagLabels = await getProjectTags({ cacheTtlMs: PUBLIC_CONTENT_CACHE_TTL_MS })
const uniqueTags = uniqueTagLabels.map((label) => ({
  label,
  slug: slugify(label),
}))

let paginatedProjects = await getPaginatedProjects({
  page: currentPage,
  pageSize: PAGE_SIZE,
  cacheTtlMs: PUBLIC_CONTENT_CACHE_TTL_MS,
})

const initialLastPage = Math.max(1, Math.ceil(paginatedProjects.totalItems / PAGE_SIZE))
const safePage = Math.min(currentPage, initialLastPage)

if (safePage !== currentPage) {
  paginatedProjects = await getPaginatedProjects({
    page: safePage,
    pageSize: PAGE_SIZE,
    cacheTtlMs: PUBLIC_CONTENT_CACHE_TTL_MS,
  })
}

const pageProjects = paginatedProjects.items.map((project, index) => ({
  ...project,
  featuredImage: project.coverImageUrl || fallbackProjectImages[index % fallbackProjectImages.length],
}))
const totalProjects = paginatedProjects.totalItems
const lastPage = Math.max(1, Math.ceil(totalProjects / PAGE_SIZE))
const startIndex = (safePage - 1) * PAGE_SIZE
const endIndex = startIndex + PAGE_SIZE
const viewStart = totalProjects === 0 ? 0 : startIndex + 1
const viewEnd = totalProjects === 0 ? 0 : Math.min(endIndex, totalProjects)
const previousPageHref = safePage > 1 ? (safePage === 2 ? '/portfolio' : `/portfolio/${safePage - 1}`) : null
const nextPageHref = safePage < lastPage ? `/portfolio/${safePage + 1}` : null
const firstPageHref = safePage > 1 ? '/portfolio' : null
const lastPageHref = safePage < lastPage ? `/portfolio/${lastPage}` : null
---

<DefaultLayout
  title="Experience & Portfolio | Ibnu Rizal Mutaqim"
  description="Selected works and professional experience of Ibnu Rizal Mutaqim across web development projects."
>
  <PageHeader title="Pengalaman & Portofolio" subtitle="Daftar proyek dan pengalaman saya." bgType="gradient" />

  <section class="portfolio-list my-10 md:my-12">
    <div class="container">
      <Heading level="h2" size="h5" class="mb-2">Tag</Heading>
      <div class="tag-cloud flex flex-wrap gap-3 md:gap-4">
        {
          uniqueTags.map((tag: { label: string; slug: string }) => (
            <Link href={'/portfolio/tag/' + tag.slug}>{tag.label}</Link>
          ))
        }
      </div>
      <p class="mt-6 text-sm md:mt-8">
        <em>Menampilkan proyek {viewStart} sampai {viewEnd} dari total {totalProjects} proyek</em>
      </p>
      <ul class="portfolio-grid mt-3">
        {
          pageProjects.map((project) => (
            <li>
              <PublicContentCard
                imageLoading="lazy"
                fetchpriority="low"
                img={project.featuredImage}
                url={'/portfolio/' + project.slug}
                title={project.title}
                headingLevel="h2"
                footer={'Peran: ' + project.author}
                fullHeight={true}
              >
                <span slot="meta">
                  {project.tags.map((tag) => (
                    <Badge>{tag}</Badge>
                  ))}
                </span>
                {project.description}
              </PublicContentCard>
            </li>
          ))
        }
      </ul>
      {
        lastPage > 1 && (
          <div class="mt-10 grid place-content-center md:mt-12">
            <Pagination
              firstPage={firstPageHref}
              previousPage={previousPageHref}
              nextPage={nextPageHref}
              lastPage={lastPageHref}
              currentPage={`${safePage}`}
              totalPages={`${lastPage}`}
              ariaLabel="Pagination portofolio"
            />
          </div>
        )
      }
    </div>
  </section>
</DefaultLayout>

<style lang="scss" is:global>
  .portfolio-list .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(250px, 100%), 1fr));
    gap: clamp(1rem, 2.2vw, 1.45rem);
  }

  .portfolio-list .portfolio-grid > li {
    min-inline-size: 0;
  }

  .portfolio-list .portfolio-grid :is(h2, h3, h4, p, a, span) {
    overflow-wrap: anywhere;
  }

  .portfolio-list .tag-cloud a {
    white-space: normal;
    overflow-wrap: anywhere;
  }
</style>
