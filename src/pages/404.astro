---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
---

<DefaultLayout title="Page Not Found | Ibnu Rizal Mutaqim" description="The page you are looking for does not exist." noindex={true}>
  <section class="my-12">
    <div class="container">
      <Heading level="h1">404</Heading>
    </div>
  </section>
  <section class="my-12">
    <div class="space-content container">
      <p class="text-2xl">Halaman yang kamu cari tidak ditemukan.</p>
      <Link href="/" isButton type="primary" animateOnHover animationType="nudge">
        Back to About Me
        <Icon aria-hidden="true" name="lucide:house" size="1.5rem" />
      </Link>
    </div>
  </section>
</DefaultLayout>
