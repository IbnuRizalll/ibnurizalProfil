---
import themeConfig from '@theme-config'
import AdminSectionNav from '@components/admin/AdminSectionNav.astro'
import AboutAdminScript from '@components/admin/scripts/AboutAdminScript.astro'

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? ''
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? ''
const supabaseAssetsBucket = import.meta.env.PUBLIC_SUPABASE_ASSETS_BUCKET ?? 'site-assets'
const rawAdminIdleTimeoutMinutes = Number.parseInt(import.meta.env.PUBLIC_ADMIN_IDLE_TIMEOUT_MINUTES ?? '20', 10)
const adminIdleTimeoutMinutes = Number.isFinite(rawAdminIdleTimeoutMinutes)
  ? Math.min(30, Math.max(15, rawAdminIdleTimeoutMinutes))
  : 20
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Admin - Edit About Me</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <style
      is:global
      define:vars={{
        brandPrimary: themeConfig.colors.primary,
        brandSecondary: themeConfig.colors.secondary,
        brandNeutral: themeConfig.colors.neutral,
        brandOutline: themeConfig.colors.outline,
      }}
    >
      :root {
        color-scheme: light dark;
        --brand-primary: var(--brandPrimary);
        --brand-secondary: var(--brandSecondary);
        --brand-neutral: var(--brandNeutral);
        --brand-outline: var(--brandOutline);
        --text-color: light-dark(#1f2530, #f8f9fc);
        --surface: light-dark(rgba(255, 255, 255, 0.8), rgba(20, 24, 30, 0.9));
        --surface-soft: light-dark(rgba(247, 250, 253, 0.88), rgba(32, 37, 44, 0.9));
        --border-soft: light-dark(rgba(31, 37, 48, 0.14), rgba(244, 247, 250, 0.15));
        --status-info: #2f6fd8;
        --status-success: #16803d;
        --status-error: #b42318;
        --shadow-lg: 0 24px 54px rgba(7, 12, 18, 0.18);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background:
          radial-gradient(
            circle at 0% -12%,
            color-mix(in oklab, var(--brand-primary) 34%, transparent),
            transparent 38%
          ),
          radial-gradient(
            circle at 100% -8%,
            color-mix(in oklab, var(--brand-secondary) 28%, transparent),
            transparent 35%
          ),
          linear-gradient(160deg, light-dark(#f8f9fd, #0f1318), light-dark(#edf1f7, #141a21));
        min-height: 100vh;
        color: var(--text-color);
        line-height: 1.55;
        font-family:
          Atkinson Hyperlegible,
          ui-sans-serif,
          system-ui,
          -apple-system,
          sans-serif;
      }

      body::before {
        position: fixed;
        opacity: 0.23;
        inset: 0;
        background-image:
          linear-gradient(to right, color-mix(in oklab, var(--brand-neutral) 30%, transparent) 1px, transparent 1px),
          linear-gradient(to bottom, color-mix(in oklab, var(--brand-neutral) 30%, transparent) 1px, transparent 1px);
        background-size: 24px 24px;
        pointer-events: none;
        content: '';
      }

      .admin-shell {
        position: relative;
        margin-inline: auto;
        padding: clamp(1rem, 2.8vw, 2rem);
        max-width: 1220px;
      }

      .panel {
        backdrop-filter: blur(10px);
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--border-soft);
        border-radius: 20px;
        background: var(--surface);
      }

      .admin-header {
        display: grid;
        gap: 1rem;
        padding: clamp(1rem, 2.6vw, 1.5rem);
      }

      .eyebrow {
        margin: 0;
        color: color-mix(in oklab, var(--text-color) 70%, transparent);
        font-weight: 700;
        font-size: 0.82rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      h1,
      h2,
      p {
        margin: 0;
      }

      h1 {
        margin-top: 0.35rem;
        font-size: clamp(1.55rem, 3.6vw, 2.3rem);
        line-height: 1.15;
      }

      .lead {
        margin-top: 0.38rem;
        max-width: 60ch;
        color: color-mix(in oklab, var(--text-color) 78%, transparent);
      }

      .header-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.6rem;
      }

      .link-chip,
      .button {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 0.35rem;
        transition:
          transform 140ms ease,
          box-shadow 200ms ease,
          border-color 160ms ease,
          background-color 160ms ease;
        cursor: pointer;
        border: 1px solid var(--border-soft);
        border-radius: 12px;
        background: color-mix(in oklab, var(--surface-soft) 82%, transparent);
        padding: 0.62rem 0.85rem;
        color: inherit;
        font: inherit;
        font-weight: 700;
        text-decoration: none;
      }

      .link-chip:hover,
      .button:hover {
        transform: translateY(-1px);
        border-color: color-mix(in oklab, var(--brand-primary) 36%, var(--border-soft));
        background: color-mix(in oklab, var(--surface-soft) 62%, var(--brand-primary) 16%);
      }

      .button.primary {
        border-color: color-mix(in oklab, var(--brand-primary) 35%, var(--border-soft));
        background: linear-gradient(
          140deg,
          color-mix(in oklab, var(--brand-primary) 20%, var(--surface-soft)),
          color-mix(in oklab, var(--brand-secondary) 14%, var(--surface-soft))
        );
      }

      .button.ghost {
        background: color-mix(in oklab, var(--surface-soft) 70%, transparent);
      }

      .button:focus-visible,
      .link-chip:focus-visible,
      input:focus-visible,
      textarea:focus-visible {
        outline: 2px solid transparent;
        box-shadow: 0 0 0 3px color-mix(in oklab, var(--brand-outline) 28%, transparent);
      }

      .button[disabled] {
        transform: none;
        opacity: 0.6;
        cursor: not-allowed;
      }

      .admin-section-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin: 1rem 0;
        padding: clamp(0.8rem, 2vw, 1rem);
      }

      .nav-link.is-active {
        border-color: color-mix(in oklab, var(--brand-primary) 45%, var(--border-soft));
        background: linear-gradient(
          145deg,
          color-mix(in oklab, var(--brand-primary) 22%, var(--surface-soft)),
          color-mix(in oklab, var(--brand-secondary) 14%, var(--surface-soft))
        );
      }

      .status {
        margin: 1rem 0;
        border: 1px solid var(--border-soft);
        border-radius: 12px;
        background: color-mix(in oklab, var(--surface-soft) 88%, transparent);
        padding: 0.72rem 0.85rem;
      }

      .status.info {
        border-color: color-mix(in oklab, var(--status-info) 52%, var(--border-soft));
      }

      .status.success {
        border-color: color-mix(in oklab, var(--status-success) 52%, var(--border-soft));
      }

      .status.error {
        border-color: color-mix(in oklab, var(--status-error) 52%, var(--border-soft));
      }

      body[data-admin-auth-pending='true'] .admin-header,
      body[data-admin-auth-pending='true'] .admin-section-nav,
      body[data-admin-auth-pending='true'] #app-section {
        display: none !important;
      }

      body[data-admin-auth-pending='true'] #status {
        margin-top: clamp(18vh, 24vh, 28vh);
      }

      .editor-panel {
        padding: clamp(1rem, 2.4vw, 1.35rem);
      }

      .panel-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.8rem;
        margin-bottom: 0.95rem;
      }

      .panel-head p {
        margin-top: 0.28rem;
        color: color-mix(in oklab, var(--text-color) 74%, transparent);
        font-size: 0.95rem;
      }

      .editor-form {
        display: grid;
        gap: 0.9rem;
      }

      .field-grid {
        display: grid;
        gap: 0.8rem;
      }

      .field-grid.two {
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .field {
        display: grid;
        gap: 0.35rem;
      }

      .field label {
        font-weight: 700;
        font-size: 0.95rem;
      }

      input,
      textarea {
        transition:
          border-color 140ms ease,
          box-shadow 190ms ease;
        border: 1px solid var(--border-soft);
        border-radius: 12px;
        background: color-mix(in oklab, var(--surface-soft) 82%, transparent);
        padding: 0.72rem 0.86rem;
        width: 100%;
        color: inherit;
        font: inherit;
      }

      textarea {
        min-height: 132px;
        resize: vertical;
      }

      .field-inline-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.5rem;
        color: color-mix(in oklab, var(--text-color) 72%, transparent);
        font-size: 0.86rem;
      }

      .helper {
        margin-top: 0.05rem;
        border: 1px dashed var(--border-soft);
        border-radius: 12px;
        background: color-mix(in oklab, var(--surface-soft) 72%, transparent);
        padding: 0.65rem 0.75rem;
        color: color-mix(in oklab, var(--text-color) 76%, transparent);
        font-size: 0.92rem;
      }

      .asset-preview {
        margin-top: 0.55rem;
        border: 1px solid var(--border-soft);
        border-radius: 12px;
        background: color-mix(in oklab, var(--surface-soft) 70%, transparent);
        max-width: 100%;
      }

      .asset-preview.logo {
        padding: 0.35rem;
        width: min(100%, 160px);
        height: 96px;
        object-fit: contain;
      }

      .asset-preview.hero {
        aspect-ratio: 16 / 10;
        width: min(100%, 320px);
        object-fit: cover;
      }

      .form-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
      }

      .muted {
        color: color-mix(in oklab, var(--text-color) 74%, transparent);
      }

      @media (max-width: 860px) {
        .panel-head {
          flex-direction: column;
          align-items: flex-start;
        }

        .header-actions,
        .form-actions {
          inline-size: 100%;
        }

        .form-actions .button,
        .header-actions .button,
        .header-actions .link-chip {
          flex: 1 1 160px;
        }

        .field-inline-meta {
          flex-wrap: wrap;
          align-items: flex-start;
        }
      }

      @media (min-width: 1080px) {
        .admin-header {
          grid-template-columns: 1fr auto;
          align-items: center;
        }
      }
    </style>
  </head>
  <body
    data-admin-auth-pending="true"
    data-supabase-url={supabaseUrl}
    data-supabase-anon-key={supabaseAnonKey}
    data-supabase-assets-bucket={supabaseAssetsBucket}
    data-admin-idle-timeout-minutes={adminIdleTimeoutMinutes}
  >
    <main class="admin-shell">
      <header class="panel admin-header">
        <div>
          <p class="eyebrow">Ibnu Rizal Mutaqim CMS</p>
          <h1>Edit About Me</h1>
          <p class="lead">Kelola logo, hero image, dan konten biografi untuk halaman About Me.</p>
        </div>
        <div class="header-actions">
          <a class="link-chip" href="/">Preview website</a>
          <button class="button ghost" id="logout-button" type="button">Sign out</button>
        </div>
      </header>

      <AdminSectionNav active="about" />

      <div class="status info" id="status" role="status" aria-live="polite">Initializing...</div>

      <section id="app-section" hidden>
        <section class="panel editor-panel" aria-labelledby="settings-title">
          <div class="panel-head">
            <div>
              <h2 id="settings-title">Site Settings & About Me</h2>
              <p>Atur branding website dan konten halaman About Me.</p>
            </div>
          </div>

          <form id="settings-form" class="editor-form" aria-describedby="settings-help">
            <div class="field-grid two">
              <div class="field">
                <label for="settings-logo-url">Logo URL</label>
                <input id="settings-logo-url" type="text" placeholder="/logo.svg atau https://domain.com/logo.png" />
                <p class="muted">Bisa URL manual atau upload file.</p>
              </div>
              <div class="field">
                <label for="settings-home-image-url">Home Hero Image URL</label>
                <input
                  id="settings-home-image-url"
                  type="text"
                  placeholder="/astronaut-hero-img.webp atau https://domain.com/hero.jpg"
                />
                <p class="muted">Bisa URL manual atau upload file.</p>
              </div>
            </div>

            <div class="field-grid two">
              <div class="field">
                <label for="settings-logo-file">Upload Logo</label>
                <input id="settings-logo-file" type="file" accept="image/png,image/jpeg,image/webp,image/gif" />
                <p class="muted">Maks 5MB. Format: PNG, JPG, WEBP, GIF.</p>
                <img id="settings-logo-preview" class="asset-preview logo" alt="Logo preview" hidden />
              </div>
              <div class="field">
                <label for="settings-home-image-file">Upload Hero Image</label>
                <input id="settings-home-image-file" type="file" accept="image/png,image/jpeg,image/webp,image/gif" />
                <p class="muted">Maks 5MB. Format: PNG, JPG, WEBP, GIF.</p>
                <img id="settings-home-image-preview" class="asset-preview hero" alt="Hero image preview" hidden />
              </div>
            </div>

            <div class="field">
              <label for="settings-hero-description">Hero Description</label>
              <textarea id="settings-hero-description" required></textarea>
              <div class="field-inline-meta">
                <span>Teks deskripsi di bagian hero halaman About Me.</span><span id="settings-hero-count">0 chars</span
                >
              </div>
            </div>

            <div class="field">
              <label for="settings-about-me">About Me Content</label>
              <textarea id="settings-about-me" required></textarea>
              <div class="field-inline-meta">
                <span>Pisahkan paragraf dengan baris kosong jika diperlukan.</span><span id="settings-about-count"
                  >0 chars</span
                >
              </div>
            </div>

            <p class="helper" id="settings-help">
              Jika upload file, URL public akan otomatis disimpan ke field URL (bucket:
              <strong>{supabaseAssetsBucket}</strong>).
            </p>

            <div class="form-actions">
              <button class="button primary" type="submit" id="settings-save-button">Save settings</button>
              <button class="button" type="button" id="settings-reset-button">Reset fields</button>
              <button class="button" type="button" id="settings-delete-button">Delete settings row</button>
            </div>
          </form>
        </section>
      </section>
    </main>

    <AboutAdminScript />
  </body>
</html>
