---
import ResponsiveToggle from './ResponsiveToggle.astro'
import NavigationItems from './NavigationItems.astro'
import Logo from './Logo.astro'
import themeConfig from '@theme-config'
import { DarkMode } from 'accessible-astro-components'
import { LauncherTrigger } from 'accessible-astro-launcher'
import { Icon } from 'astro-icon/components'

/**
 * Navigation Component
 *
 * @description A component that displays the navigation menu for the website
 */
type NavigationItem = (typeof themeConfig.navigation.items)[number]
type NavigationLinkItem = Extract<NavigationItem, { href: string }>

const isNavigationLinkItem = (item: NavigationItem): item is NavigationLinkItem => 'href' in item

const mobileGithubItem = themeConfig.navigation.items.find(
  (item): item is NavigationLinkItem => isNavigationLinkItem(item) && item.icon === 'lucide:github' && !!item.href,
)
---

<div id="main-navigation" class="py-2 md:py-4">
  <div class="container">
    <Logo />
    <div class="wrapper">
      <nav class="desktop-menu" aria-label="Main navigation desktop">
        <NavigationItems />
      </nav>
      <div class="mobile-controls">
        {
          mobileGithubItem && (
            <a
              class="mobile-quick-action mobile-github"
              href={mobileGithubItem.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={mobileGithubItem.label}
            >
              <Icon aria-hidden="true" name={mobileGithubItem.icon!} size="22" />
              <span class="sr-only">{mobileGithubItem.label}</span>
            </a>
          )
        }
        {
          themeConfig.navigation.darkmode && (
            <div class="mobile-theme-toggle menu-item type-icon animate-rotate">
              <DarkMode>
                <Icon aria-hidden="true" name="lucide:moon" slot="light" />
                <Icon aria-hidden="true" name="lucide:sun" slot="dark" />
              </DarkMode>
            </div>
          )
        }
        <ResponsiveToggle />
        <div class="mobile-launcher">
          <LauncherTrigger launcherId="site-launcher" iconOnly={true} gradientBorder={true} />
        </div>
      </div>
    </div>
    <nav class="mobile-menu" aria-label="Main navigation mobile">
      <NavigationItems />
    </nav>
  </div>
</div>

<script>
  declare global {
    interface Window {
      __siteNavigationCleanup?: (() => void) | undefined
      __siteNavigationListenerBound?: boolean | undefined
    }
  }

  const initSiteNavigation = () => {
    if (typeof window === 'undefined') return

    if (typeof window.__siteNavigationCleanup === 'function') {
      window.__siteNavigationCleanup()
      window.__siteNavigationCleanup = undefined
    }

    const mainNav = document.querySelector<HTMLElement>('#main-navigation')
    if (!mainNav) return

    const navLists = [...mainNav.querySelectorAll('nav > ul')] as HTMLUListElement[]
    const dropdownMenus = [...mainNav.querySelectorAll('.has-dropdown > button')] as HTMLButtonElement[]
    const controller = new AbortController()
    const { signal } = controller

    const normalizePath = (path: string): string => {
      if (!path || path === '/') return '/'
      return path.endsWith('/') ? path.slice(0, -1) : path
    }

    const setActiveMenuItem = (): void => {
      const currentPathname = normalizePath(window.location.pathname)

      navLists.forEach((menu) => {
        const menuItems = [...menu.querySelectorAll('a[href]:not([rel*="external"])')] as HTMLAnchorElement[]

        menuItems.forEach((menuItem) => {
          menuItem.classList.remove('is-active')
          menuItem.removeAttribute('aria-current')

          const itemPath = normalizePath(menuItem.pathname)
          const isRootPath = itemPath === '/'
          const isActive = isRootPath
            ? currentPathname === '/'
            : currentPathname === itemPath || currentPathname.startsWith(`${itemPath}/`)

          if (isActive) {
            menuItem.classList.add('is-active')
            menuItem.setAttribute('aria-current', 'page')
          }
        })
      })
    }

    const isOutOfViewport = (element: Element): boolean => {
      const elementBounds = element.getBoundingClientRect()
      return elementBounds.right > (window.innerWidth || document.documentElement.clientWidth)
    }

    const closeDropdownMenu = (dropdownMenu: HTMLButtonElement): void => {
      dropdownMenu.classList.remove('show')
      dropdownMenu.setAttribute('aria-expanded', 'false')
      const dropdownList = dropdownMenu.parentElement?.querySelector('ul') as HTMLUListElement | null
      if (dropdownList) {
        dropdownList.style.left = ''
      }
    }

    const closeAllDropdownMenus = (except?: HTMLButtonElement): void => {
      dropdownMenus.forEach((dropdownMenu) => {
        if (dropdownMenu !== except) {
          closeDropdownMenu(dropdownMenu)
        }
      })
    }

    const openDropdownMenu = (dropdownMenu: HTMLButtonElement): void => {
      const dropdownList = dropdownMenu.parentElement?.querySelector('ul') as HTMLUListElement | null
      if (!dropdownList) return

      closeAllDropdownMenus(dropdownMenu)
      dropdownMenu.classList.add('show')
      dropdownMenu.setAttribute('aria-expanded', 'true')
      dropdownList.style.left = ''

      if (isOutOfViewport(dropdownList)) {
        dropdownList.style.left = 'auto'
      }
    }

    const focusMenuTarget = (targetItem: Element | null): void => {
      if (!targetItem) return
      const focusableElement = targetItem.matches('a, button, input')
        ? (targetItem as HTMLElement)
        : ((targetItem.querySelector('a, button, input') as HTMLElement | null) ?? null)
      focusableElement?.focus()
    }

    const handleMenuKeydown = (event: KeyboardEvent): void => {
      const currentMenu = event.currentTarget as HTMLUListElement
      const element = event.target as Element
      const currentMenuItem = element.closest('li')
      const menuItems = [...currentMenu.querySelectorAll(':scope > .menu-item')] as HTMLLIElement[]
      const currentDropdownMenu = element.closest('.has-dropdown > button') as HTMLButtonElement | null
      const currentDropdownMenuItem = element.closest('.has-dropdown li') as HTMLLIElement | null
      const currentIndex = currentMenuItem ? menuItems.findIndex((item) => item === currentMenuItem) : -1

      const key = event.key
      let targetItem: Element | null = null

      if (key === 'ArrowRight') {
        if (currentMenuItem && menuItems.indexOf(currentMenuItem as HTMLLIElement) === menuItems.length - 1) {
          targetItem = menuItems[0]
        } else if (currentMenuItem && currentIndex >= 0) {
          targetItem = menuItems[currentIndex + 1]
        }
      }

      if (key === 'ArrowLeft') {
        if (currentMenuItem && menuItems.indexOf(currentMenuItem as HTMLLIElement) === 0) {
          targetItem = menuItems[menuItems.length - 1]
        } else if (currentMenuItem && currentIndex >= 0) {
          targetItem = menuItems[currentIndex - 1]
        }
      }

      if (key === 'Escape') {
        targetItem = menuItems[0] ?? null
      }

      if (currentDropdownMenu) {
        const nextElement = currentDropdownMenu.nextElementSibling as Element | null
        if (nextElement) {
          const firstDropdownItem = nextElement.querySelector('li')

          if (key === 'ArrowDown') {
            event.preventDefault()
            openDropdownMenu(currentDropdownMenu)
            targetItem = firstDropdownItem
          }
        }

        if (key === 'Escape') {
          closeDropdownMenu(currentDropdownMenu)
        }
      }

      if (currentDropdownMenuItem) {
        const currentDropdownList = currentDropdownMenuItem.parentElement
        if (currentDropdownList) {
          const dropdownMenuItems = [...currentDropdownList.querySelectorAll('li')] as HTMLLIElement[]
          const dropdownIndex = dropdownMenuItems.findIndex((item) => item === currentDropdownMenuItem)

          if (key === 'ArrowDown') {
            event.preventDefault()
            targetItem =
              dropdownMenuItems.indexOf(currentDropdownMenuItem) === dropdownMenuItems.length - 1
                ? dropdownMenuItems[0]
                : dropdownMenuItems[dropdownIndex + 1]
          }

          if (key === 'ArrowUp') {
            event.preventDefault()
            targetItem =
              dropdownMenuItems.indexOf(currentDropdownMenuItem) === 0
                ? dropdownMenuItems[dropdownMenuItems.length - 1]
                : dropdownMenuItems[dropdownIndex - 1]
          }

          if (key === 'Escape') {
            const dropdownParentButton = currentDropdownList.previousElementSibling as HTMLButtonElement | null
            if (dropdownParentButton) {
              targetItem = dropdownParentButton.parentElement
              closeAllDropdownMenus()
            }
          }

          if (key === 'Tab') {
            const dropdownParentButton = currentDropdownList.previousElementSibling as HTMLButtonElement | null
            if (
              dropdownParentButton &&
              dropdownMenuItems.indexOf(currentDropdownMenuItem) === dropdownMenuItems.length - 1
            ) {
              closeDropdownMenu(dropdownParentButton)
            }
          }
        }
      }

      focusMenuTarget(targetItem)
    }

    const handleNavClick = (event: MouseEvent): void => {
      const element = event.target as Element
      const mobileLink = element.closest('.mobile-menu a[href]') as HTMLAnchorElement | null
      if (mobileLink && mainNav.contains(mobileLink)) {
        closeAllDropdownMenus()
        window.dispatchEvent(new Event('site-mobile-nav:close'))
        return
      }

      const dropdownButton = element.closest('.has-dropdown > button') as HTMLButtonElement | null
      if (!dropdownButton || !mainNav.contains(dropdownButton)) return

      if (dropdownButton.getAttribute('aria-expanded') === 'false') {
        openDropdownMenu(dropdownButton)
      } else {
        closeDropdownMenu(dropdownButton)
      }
    }

    const handleWindowClick = (event: MouseEvent): void => {
      const element = event.target as Element | null
      if (!element || mainNav.contains(element)) return
      closeAllDropdownMenus()
    }

    navLists.forEach((menu) => {
      menu.addEventListener('keydown', handleMenuKeydown, { signal })
    })

    mainNav.addEventListener('click', handleNavClick, { signal })
    window.addEventListener('click', handleWindowClick, { signal })

    setActiveMenuItem()

    window.__siteNavigationCleanup = () => {
      controller.abort()
    }
  }

  initSiteNavigation()

  if (!window.__siteNavigationListenerBound) {
    document.addEventListener('astro:page-load', initSiteNavigation)
    window.__siteNavigationListenerBound = true
  }
</script>

<style lang="scss" is:global>
  @use '../assets/scss/base/mixins' as *;
  @use '../assets/scss/base/breakpoint' as *;

  #main-navigation {
    position: relative;
    z-index: 1;

    > .container {
      display: flex;
      position: relative;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: clamp(0.45rem, 2vw, 0.95rem);
      z-index: 1;
      backdrop-filter: blur(12px);
      box-shadow: var(--elevation-3);
      border: 1px solid var(--border-color-subtle);
      border-radius: var(--radius-xl);
      background: color-mix(in oklab, var(--background-color) 86%, var(--color-primary-100));
      padding: clamp(0.55rem, 1.7vw, 0.9rem) clamp(0.8rem, 2vw, 1.1rem);
      min-inline-size: 0;

      @include breakpoint('nav') {
        padding: var(--space-xs) var(--space-m);
      }
    }

    .mobile-menu {
      display: none;

      &.show {
        display: block;
      }
    }

    .mobile-controls,
    .responsive-toggle {
      display: flex;
      align-items: center;
      gap: var(--space-2xs);
    }

    .mobile-controls {
      flex-shrink: 0;
      flex-wrap: nowrap;
      justify-content: flex-end;
      min-inline-size: 0;
    }

    .mobile-quick-action,
    .mobile-theme-toggle {
      display: flex;
      flex: 0 0 auto;
      justify-content: center;
      align-items: center;
      transition:
        transform var(--animation-speed-fast) var(--cubic-bezier),
        border-color var(--animation-speed-fast) var(--cubic-bezier),
        background-color var(--animation-speed-fast) var(--cubic-bezier);
      border: 1px solid var(--border-color-subtle);
      border-radius: var(--radius-large);
      background: color-mix(in oklab, var(--background-color) 92%, var(--color-primary-100));
      min-inline-size: 2.7rem;
      min-block-size: 2.7rem;
    }

    .mobile-quick-action {
      text-decoration: none;
    }

    .mobile-quick-action svg,
    .mobile-theme-toggle svg {
      inline-size: 1.35rem;
      block-size: 1.35rem;
    }

    .mobile-quick-action:where(:hover, :focus-visible),
    .mobile-theme-toggle:where(:hover, :focus-within) {
      transform: translateY(-1px);
      border-color: color-mix(in oklab, var(--link-color) 45%, var(--border-color-subtle));
      background: color-mix(in oklab, var(--background-color) 84%, var(--color-secondary-200));
    }

    .mobile-theme-toggle {
      overflow: hidden;

      .darkmode-toggle {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        box-shadow: none;
        border: none;
        background: transparent;
        padding: 0;
        min-inline-size: 2.7rem;
        min-block-size: 2.7rem;
      }
    }

    .mobile-launcher {
      display: flex;
      flex: 0 0 auto;
    }

    .desktop-menu {
      display: none;
    }

    @include breakpoint('nav') {
      .mobile-menu {
        display: none;
      }

      .responsive-toggle {
        display: none;
      }

      .mobile-quick-action,
      .mobile-theme-toggle,
      .mobile-launcher {
        display: none;
      }

      .desktop-menu {
        display: block;
      }
    }

    .wrapper {
      display: flex;
      flex: 0 1 auto;
      flex-wrap: nowrap;
      justify-content: flex-end;
      align-items: center;
      gap: clamp(0.45rem, 1.7vw, 0.8rem);
      margin-inline-start: auto;
      min-inline-size: 0;

      @include breakpoint('nav') {
        gap: var(--space-m);
      }
    }

    a,
    button {
      color: var(--foreground-color);
    }

    nav {
      > ul {
        display: flex;
        gap: clamp(0.65rem, 1.8vw, 1.2rem);
        margin: 0;
        padding: 0;
        min-inline-size: 0;
        list-style-type: none;

        li {
          align-content: center;
        }

        a:hover,
        a:focus-visible,
        .is-active,
        button[aria-expanded='true'],
        .has-dropdown > button:hover,
        .has-dropdown > button:focus-visible {
          text-decoration: underline;
          text-decoration-style: wavy;
          text-decoration-thickness: 1px;
          text-underline-offset: 7px;
        }

        .is-active {
          font-weight: bold;
        }

        .highlight a {
          display: inline-flex;
          align-items: center;
          gap: var(--space-2xs);
          transition: all var(--animation-speed-fast) var(--cubic-bezier);
          margin-block-start: calc(var(--space-4xs) * -1);
          border: 1px solid var(--foreground-color);
          border-radius: var(--radius-large);
          padding: var(--space-4xs) var(--space-2xs);
          text-decoration: none;

          &:where(:hover, :focus-visible) {
            background-color: var(--foreground-color);
            color: var(--background-color) !important;
          }
        }
      }
    }

    .mobile-menu {
      flex-basis: 100%;
      margin-block-start: clamp(0.65rem, 2vw, 1rem);
      border: 1px solid var(--border-color-subtle);
      border-radius: var(--radius-l);
      background: color-mix(in oklab, var(--background-color) 88%, var(--color-secondary-100));
      padding: clamp(0.75rem, 2.4vw, 1.1rem);
      inline-size: 100%;
      overflow: hidden;

      > ul {
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-s);

        > li {
          inline-size: 100%;
        }

        > li.type-icon,
        > li.desktop-launcher {
          display: none;
        }

        ul {
          position: relative;
          margin-block-start: var(--space-m);
        }
      }

      a,
      button {
        display: block;
        padding: var(--space-2xs) 0;
        inline-size: 100%;
        text-wrap: balance;
      }
    }

    .desktop-menu {
      > ul {
        gap: clamp(0.7rem, 1.2vw, 1.15rem);

        > li > a,
        > li > button {
          font-size: clamp(0.92rem, 0.85rem + 0.22vw, 1rem);
        }
      }
    }

    .has-dropdown {
      position: relative;

      > button {
        display: flex;
        align-items: center;
        gap: var(--space-4xs);
        margin-block-start: -1px;

        svg {
          transition: all var(--animation-speed-instant) var(--cubic-bezier);
        }

        &.show {
          svg {
            scale: -1;
          }
        }
      }

      ul {
        display: none;
        position: absolute;
        flex-direction: column;
        gap: var(--space-2xs);
        translate: 0 1rem;
        opacity: 0;
        z-index: 100;
        inset-block-start: 125%;
        inset-inline-end: 0;
        inset-inline-start: 0;
        box-shadow: var(--elevation-4);
        border: 2px solid var(--border-color-subtle);
        border-radius: var(--radius-l);
        background: color-mix(in oklab, var(--background-color) 88%, var(--color-primary-100));
        padding: var(--space-m);
        min-inline-size: min(275px, calc(100vw - 2.2rem));

        @media (prefers-reduced-motion: no-preference) {
          transition-behavior: allow-discrete;
          transition-duration: var(--animation-speed-fast);
          transition-property: display, opacity, translate;
          transition-timing-function: var(--cubic-bezier);
        }
      }

      > button.show ~ ul {
        display: flex;
        translate: 0;
        opacity: 1;

        @starting-style {
          translate: 0 1rem;
          opacity: 0;
        }
      }
    }

    .darkmode-toggle {
      border: none;
      padding: 0;

      .icon {
        inline-size: clamp(24px, 5.5vw, 30px);
        block-size: clamp(24px, 5.5vw, 30px);
      }

      &:where(:hover, :focus-visible) {
        box-shadow: none;
      }

      &:focus {
        @include outline;

        &:not(:focus-visible) {
          outline: none;
          box-shadow: none;
        }
      }
    }

    @media (max-width: 480px) {
      > .container {
        gap: 0.55rem;
        border-radius: 16px;
        padding-inline: 0.72rem;
        padding-block: 0.7rem;
      }

      .wrapper {
        gap: 0.35rem;
      }

      nav > ul > li > a,
      nav > ul > li > button {
        font-size: 0.95rem;
      }

      .mobile-menu > ul {
        gap: 0.55rem;
      }
    }

    @media (max-width: 560px) {
      > .container {
        flex-wrap: nowrap;
        align-items: center;
      }

      .wrapper {
        flex: 0 1 auto;
        margin-inline-start: auto;
      }

      .mobile-controls {
        gap: 0.35rem;
        inline-size: auto;
      }

      .mobile-quick-action,
      .mobile-theme-toggle {
        min-inline-size: 2.5rem;
        min-block-size: 2.5rem;
      }
    }

    @media (max-width: 400px) {
      .mobile-controls {
        justify-content: flex-end;
      }

      .mobile-menu {
        padding-inline: 0.8rem;
      }
    }
  }
</style>
