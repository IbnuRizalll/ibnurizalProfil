---
import { Heading, Link } from 'accessible-astro-components'

interface Props {
  class?: string
  title: string
  img: string
  url: string
  imageAlt?: string
  headingLevel?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6'
  headingSize?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6'
  footer?: string
  fullHeight?: boolean
  imageLoading?: 'lazy' | 'eager'
  fetchpriority?: 'high' | 'low' | 'auto'
  width?: number
  height?: number
}

const {
  class: className,
  title,
  img,
  url,
  imageAlt = '',
  headingLevel = 'h3',
  headingSize = 'h6',
  footer = '',
  fullHeight = false,
  imageLoading = 'lazy',
  fetchpriority = 'low',
  width = 640,
  height = 360,
} = Astro.props
---

<article class:list={['public-content-card', { 'public-content-card--full-height': fullHeight }, className]}>
  <div class="public-content-card__image">
    <img
      src={img}
      alt={imageAlt}
      width={width}
      height={height}
      loading={imageLoading}
      decoding="async"
      fetchpriority={fetchpriority}
    />
  </div>
  <div class="public-content-card__content">
    <div class="public-content-card__title">
      <Heading level={headingLevel} size={headingSize}>
        <Link href={url}>{title}</Link>
      </Heading>
    </div>
    <div class="public-content-card__meta"><slot name="meta" /></div>
    <p class="public-content-card__description"><slot /></p>
    {footer && <small class="public-content-card__footer">{footer}</small>}
  </div>
</article>

<style>
  :where(.public-content-card) {
    --card-radius: clamp(1.25rem, 2vw, 1.6rem);
    --transition-duration: 0.3s;
    --transition-easing: cubic-bezier(0.165, 0.84, 0.44, 1);

    display: flex;
    position: relative;
    flex-direction: column;
    box-shadow:
      0 26px 50px color-mix(in oklab, black 20%, transparent),
      0 0 0 1px color-mix(in oklab, var(--brand-secondary) 12%, transparent);
    border: 1px solid color-mix(in oklab, var(--brand-secondary) 28%, var(--border-color-subtle) 72%);
    border-radius: var(--card-radius);
    background: linear-gradient(
      145deg,
      color-mix(in oklab, var(--background-color) 84%, var(--brand-primary) 16%),
      color-mix(in oklab, var(--background-color) 92%, black 8%)
    );
    max-inline-size: 60ch;
    max-block-size: 100%;
    overflow: hidden;
    color: inherit;
  }

  @media (prefers-reduced-motion: no-preference) {
    :where(.public-content-card) {
      transition: box-shadow var(--transition-duration) var(--transition-easing);
    }
  }

  :where(.public-content-card--full-height) {
    block-size: 100%;
  }

  :where(.public-content-card:hover),
  :where(.public-content-card:focus-within) {
    box-shadow:
      0 28px 56px color-mix(in oklab, black 22%, transparent),
      0 0 0 1px color-mix(in oklab, var(--brand-secondary) 24%, transparent);
  }

  :where(.public-content-card:focus-within) a:focus {
    outline: none;
    box-shadow: none;
    text-decoration: none;
  }

  :where(.public-content-card__image) {
    display: grid;
    position: relative;
    place-items: center;
    background:
      radial-gradient(circle at top, color-mix(in oklab, var(--brand-secondary) 12%, transparent), transparent 58%),
      color-mix(in oklab, var(--background-color) 82%, black 18%);
    padding: clamp(0.85rem, 1.6vw, 1rem);
    block-size: 250px;
    overflow: clip;
  }

  :where(.public-content-card__image img) {
    border-radius: calc(var(--card-radius) - 0.45rem);
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  @media (prefers-reduced-motion: no-preference) {
    :where(.public-content-card__image img) {
      transition: transform var(--transition-duration) var(--transition-easing);
    }
  }

  :where(.public-content-card__content) {
    display: flex;
    flex-grow: 1;
    flex-direction: column;
    gap: 0.7rem;
    padding-inline: clamp(1rem, 2vw, 1.15rem);
    padding-block: clamp(1rem, 2vw, 1.15rem);
  }

  :where(.public-content-card a) {
    color: currentColor;
    text-decoration: none;
  }

  :where(.public-content-card a:hover),
  :where(.public-content-card a:focus-visible) {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  :where(.public-content-card:has(a:hover, a:focus-visible) .public-content-card__image img) {
    transform: scale(1.05);
  }

  :where(.public-content-card__title a)::after {
    position: absolute;
    inset: 0;
    content: '';
  }

  :where(.public-content-card__meta) {
    order: -1;
    margin-block-start: 0.5rem;
  }

  :where(.public-content-card__meta) :global(span) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  :where(.public-content-card__meta:empty) {
    display: none;
  }

  :where(.public-content-card__description) {
    margin: 0;
    overflow-wrap: anywhere;
  }

  :where(.public-content-card__footer) {
    margin-block-start: auto;
    color: color-mix(in oklab, var(--text-color) 72%, transparent);
    font-size: 0.86rem;
    line-height: 1.35;
  }
</style>
