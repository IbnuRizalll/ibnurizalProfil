---
/**
 * ResponsiveToggle Component
 *
 * @description A toggle button for mobile navigation
 */
interface Props {
  /**
   * Additional classes to apply to the ResponsiveToggle
   */
  class?: string
}

const { class: className } = Astro.props
---

<button class:list={[className, 'responsive-toggle']} aria-expanded="false" aria-label="Open menu navigation">
  <span>Menu</span>
  <svg width="26" height="21" aria-hidden="true" fill="var(--link-color)" xmlns="http://www.w3.org/2000/svg"
    ><path
      d="M2 1.667h24m-24 8h24m-24 8h24"
      stroke="var(--foreground-color)"
      stroke-width="2.667"
      stroke-linecap="round"
      stroke-linejoin="round"></path></svg
  >
</button>

<script>
  declare global {
    interface Window {
      __responsiveToggleCleanup?: (() => void) | undefined
      __responsiveToggleListenerBound?: boolean | undefined
    }
  }

  const initResponsiveToggle = () => {
    if (typeof window === 'undefined') return

    if (typeof window.__responsiveToggleCleanup === 'function') {
      window.__responsiveToggleCleanup()
      window.__responsiveToggleCleanup = undefined
    }

    const responsiveToggle = document.querySelector<HTMLElement>('.responsive-toggle')
    const mobileNavigation = document.querySelector<HTMLElement>('.mobile-menu')
    if (!responsiveToggle || !mobileNavigation) return

    const controller = new AbortController()
    const { signal } = controller

    const setToggleState = (isOpen: boolean) => {
      const text = responsiveToggle.querySelector('span')
      const icon = responsiveToggle.querySelector('svg')
      if (!text || !icon) return

      text.textContent = isOpen ? 'Close' : 'Menu'
      responsiveToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false')
      responsiveToggle.setAttribute('aria-label', isOpen ? 'Close menu navigation' : 'Open menu navigation')
      mobileNavigation.classList.toggle('show', isOpen)
      icon.innerHTML = isOpen
        ? `<path d="M10 10 2 2m8 8 8 8m-8-8 8-8m-8 8-8 8" stroke="var(--foreground-color)" stroke-width="2.667" stroke-linecap="round" stroke-linejoin="round"/>`
        : `<path d="M2 1.667h24m-24 8h24m-24 8h24" stroke="var(--foreground-color)" stroke-width="2.667" stroke-linecap="round" stroke-linejoin="round"/>`
    }

    const handleToggleClick = () => {
      const isOpen = mobileNavigation.classList.contains('show')
      setToggleState(!isOpen)
    }

    const closeMenu = () => setToggleState(false)

    responsiveToggle.addEventListener('click', handleToggleClick, { signal })
    window.addEventListener('site-mobile-nav:close', closeMenu, { signal })

    setToggleState(mobileNavigation.classList.contains('show'))

    window.__responsiveToggleCleanup = () => {
      controller.abort()
    }
  }

  initResponsiveToggle()

  if (!window.__responsiveToggleListenerBound) {
    document.addEventListener('astro:page-load', initResponsiveToggle)
    window.__responsiveToggleListenerBound = true
  }
</script>

<style lang="scss">
  @use '../assets/scss/base/breakpoint' as *;

  .responsive-toggle {
    display: none;
    justify-content: center;
    align-items: center;
    border: none;
    background: transparent;
    padding: 0;
    min-inline-size: fit-content;
    white-space: nowrap;

    span {
      margin-inline-end: var(--space-3xs);
    }

    svg {
      width: 30px;

      path {
        transition: fill var(--animation-speed-fast) var(--cubic-bezier);
      }
    }

    &:where(:hover, :focus-visible) {
      span {
        text-decoration: underline;
        text-decoration-style: wavy;
        text-decoration-thickness: 1px;
        text-underline-offset: 7px;
      }
    }
  }

  @media (max-width: 420px) {
    .responsive-toggle {
      font-size: 0.95rem;
    }

    .responsive-toggle svg {
      width: 28px;
    }
  }
</style>
