---
import HighlightShowcaseSlider from '@components/HighlightShowcaseSlider.astro'
import { getBlogPosts, type BlogPost } from '@server/content/blog-posts'

interface Props {
  class?: string
  limit?: number
  title?: string
  posts?: BlogPost[]
}

const { class: className, limit = 3, title = 'Latest Blog Notes', posts: providedPosts } = Astro.props

const postItems = Array.isArray(providedPosts) ? providedPosts : await getBlogPosts({ limit })
const postImages = [
  '/posts/post-image-1.png',
  '/posts/post-image-2.png',
  '/posts/post-image-3.png',
  '/posts/post-image-4.png',
  '/posts/post-image-5.png',
  '/posts/post-image-6.png',
]

const featuredPosts = postItems.map((post, index) => ({
  id: post.id,
  title: post.title,
  description: post.description,
  image: post.coverImageUrl || postImages[index % postImages.length],
  url: '/blog/' + post.slug,
  footer: 'By: ' + post.author,
  tags: post.tags,
}))
---

<HighlightShowcaseSlider
  class={className}
  title={title}
  items={featuredPosts}
  linkHref="/blog/"
  linkLabel="View all notes"
  helperText="Geser preview tulisan untuk melihat highlight lain, atau pakai tombol panah."
  emptyMessage="Tulisan masih kosong. Next time aku isii."
/>
