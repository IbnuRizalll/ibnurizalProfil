---
import HighlightShowcaseSlider from '@components/HighlightShowcaseSlider.astro'
import { getProjects, type PortfolioProject } from '@server/content/projects'

interface Props {
  class?: string
  limit?: number
  title?: string
  projects?: PortfolioProject[]
}

const { class: className, limit = 3, title = 'Proyek unggulan', projects: providedProjects } = Astro.props

const projectItems = Array.isArray(providedProjects) ? providedProjects : await getProjects({ limit })
const projectImages = [
  '/projects/project-image-1.png',
  '/projects/project-image-2.png',
  '/projects/project-image-3.png',
  '/projects/project-image-4.png',
  '/projects/project-image-5.png',
  '/projects/project-image-6.png',
]

const featuredProjects = projectItems.map((project, index) => ({
  id: project.id,
  title: project.title,
  description: project.description,
  image: project.coverImageUrl || projectImages[index % projectImages.length],
  url: '/portfolio/' + project.slug,
  footer: 'Peran: ' + project.author,
  tags: project.tags,
}))
---

<HighlightShowcaseSlider
  class={className}
  title={title}
  items={featuredProjects}
  linkHref="/portfolio/"
  linkLabel="View all projects"
  helperText="Geser preview proyek untuk melihat semua highlight, atau pakai tombol panah."
  emptyMessage="Konten proyek sedang diperbarui. Silakan cek kembali dalam beberapa waktu."
/>
